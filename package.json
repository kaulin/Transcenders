{
  "name": "transcenders",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "web"
  ],
  "version": "1.0.0",
  "description": "transcenders",
  "author": "",
  "license": "ISC",
  "scripts": {
    "with-env": "dotenv -e .env --",
    "dev:all": "npm run with-env ./scripts/dev-all.sh",
    "dev:backend": "./scripts/dev-backend.sh",
    "build": "npm run build:packages && npm run build:services",
    "build:packages": "npm run build --workspace=@transcenders/contracts && npm run build --workspace=@transcenders/server-utils && npm run build --workspace=@transcenders/fastify-server && npm run build --workspace=@transcenders/api-client",
    "build:services": "npm run build --workspace=auth-service --workspace=user-service --workspace=score-service",
    "clean": "npm run clean --workspaces --if-present && find . -name 'tsconfig.tsbuildinfo' -delete",
    "start": "npm run start:all",
    "start:user": "./scripts/env-gen.sh production && npm run with-env npm run start --workspace=user-service",
    "start:auth": "./scripts/env-gen.sh production && npm run with-env npm run start --workspace=auth-service",
    "start:score": "./scripts/env-gen.sh production && npm run with-env npm run start --workspace=score-service",
    "start:all": "./scripts/env-gen.sh production && npm run with-env ./scripts/start-all.sh",
    "test": "tsx scripts/tests.ts",
    "api-client-test": "tsx scripts/api-client-test.ts",
    "reglogin": "tsx scripts/reglogin.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:backend": "eslint packages services",
    "lint:frontend": "npm run lint --workspace=web",
    "lint:check": "eslint . --max-warnings 0",
    "type-check": "tsc --project tsconfig.typecheck.json",
    "type-check:watch": "tsc --project tsconfig.typecheck.json --watch"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "dotenv-cli": "^9.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "dependencies": {
    "env-schema": "^6.0.1"
  }
}
